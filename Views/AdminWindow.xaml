<Window x:Class="MeatShop.Views.AdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MeatShop.Views"
        mc:Ignorable="d"
        Title="AdminWindow" Height="450" Width="650"
        WindowStartupLocation="CenterScreen" MinWidth="600" MinHeight="400">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DataGrid x:Name="usersDataGrid" Grid.Row="0" Margin="0,0,0,10" 
                  AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single"
                  SelectionChanged="usersDataGrid_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding UserId}" Width="50"/>
                <DataGridTextColumn Header="Логин" Binding="{Binding Login}" Width="*"/>
                <DataGridTextColumn Header="Пароль" Binding="{Binding Password}" Width="100"/>
                <DataGridTextColumn Header="Роль" Binding="{Binding Role}" Width="120"/>
                <DataGridCheckBoxColumn Header="Заблокирован" Binding="{Binding IsLocked}" Width="100"/>
                <DataGridTextColumn Header="Попытки" Binding="{Binding FailedAttempts}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="1" Padding="10" Background="#FFF0F0F0" BorderBrush="LightGray" BorderThickness="1" CornerRadius="3">
            <StackPanel Orientation="Horizontal">
                <TextBox x:Name="userLoginTextBox" Width="100" Margin="0,0,5,0" ToolTip="Логин"/>
                <TextBox x:Name="userPasswordTextBox" Width="100" Margin="0,0,5,0" ToolTip="Пароль"/>

                <ComboBox x:Name="roleComboBox" Width="120" Margin="0,0,10,0" SelectedIndex="0">
                    <ComboBoxItem Content="Администратор"/>
                    <ComboBoxItem Content="Пользователь"/>
                </ComboBox>

                <Button x:Name="addUserButton" Content="Добавить" Width="80" Margin="0,0,5,0" Click="addUserButton_Click"/>
                <Button x:Name="editUserButton" Content="Сохранить изменения" Width="130" Margin="0,0,20,0" Click="editUserButton_Click"/>

                <Button x:Name="unlockUserButton" Content="Разблокировать" Width="110" Click="unlockUserButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
