<Window x:Class="Api232.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Api232"
        mc:Ignorable="d"
        Title="Валидация данных" WindowStartupLocation="CenterScreen" MinHeight="250" MinWidth="800" MaxHeight="250" MaxWidth="800">
    <Grid>
        <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center" Width="700">
            <StackPanel Margin="0 0 0 20" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                <Button Height="40" Width="250" x:Name="RequestApi" Margin="0 0 30 0" Click="RequestApi_Click" Content="Получить данные"/>
                <TextBlock x:Name="TBApi" Width="400" TextAlignment="Left" VerticalAlignment="Center"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                <Button x:Name="BtnResult" Height="40" Width="250" Click="BtnResult_Click" Margin="0 0 30 0" Content="Отправить результат теста"/>
                <TextBlock Width="400" x:Name="TBAnswer" TextAlignment="Left" VerticalAlignment="Center"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>